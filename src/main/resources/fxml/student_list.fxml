<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox fx:id="root" fx:controller="com.example.app.controller.StudentListController"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      spacing="12" styleClass="page-container">
    <padding>
        <Insets top="16" right="16" bottom="16" left="16"/>
    </padding>

    <HBox spacing="12" alignment="CENTER_LEFT">
        <Button fx:id="backBtn" text="← 返回"/>
        <Label fx:id="titleLabel" text="学生列表" styleClass="page-title" HBox.hgrow="ALWAYS"/>
        <Button fx:id="addBtn" text="新增学生" styleClass="primary"/>
    </HBox>

    <ProgressIndicator fx:id="loadingIndicator" visible="false" maxWidth="40" maxHeight="40"/>

    <Label fx:id="errorLabel" styleClass="error-message" visible="false" managed="false"/>

    <TableView fx:id="studentTable" VBox.vgrow="ALWAYS"/>
</VBox>
