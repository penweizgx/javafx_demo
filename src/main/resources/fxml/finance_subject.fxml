<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox fx:id="root" fx:controller="com.example.app.controller.FinanceSubjectController"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      spacing="12" styleClass="page-container">
    <padding>
        <Insets top="16" right="16" bottom="16" left="16"/>
    </padding>

    <HBox spacing="12" alignment="CENTER_LEFT" styleClass="page-header">
        <Label fx:id="titleLabel" text="项目标准" styleClass="page-title"/>
        <HBox HBox.hgrow="ALWAYS"/>
        <Button fx:id="addSubjectBtn" text="新增项目" styleClass="accent"/>
    </HBox>

    <HBox spacing="8" alignment="CENTER_LEFT">
        <fx:define>
            <ToggleGroup fx:id="typeFilterGroup"/>
        </fx:define>
        <RadioButton fx:id="allRadio" text="全部" toggleGroup="$typeFilterGroup" selected="true"/>
        <RadioButton fx:id="periodRadio" text="周期" toggleGroup="$typeFilterGroup"/>
        <RadioButton fx:id="onceRadio" text="一次性" toggleGroup="$typeFilterGroup"/>
    </HBox>

    <ProgressIndicator fx:id="loadingIndicator" visible="false" maxWidth="40" maxHeight="40"/>

    <Label fx:id="errorLabel" styleClass="error-message" visible="false" managed="false"/>

    <TableView fx:id="subjectTable" VBox.vgrow="ALWAYS"/>
</VBox>
