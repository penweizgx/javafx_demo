<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Separator?>
<?import javafx.geometry.Insets?>

<VBox fx:id="root" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.app.controller.EmployeeDetailController"
      spacing="12" styleClass="page-container">

    <HBox spacing="12" alignment="CENTER_LEFT" styleClass="page-header">
        <Button fx:id="backBtn" text="← 返回" styleClass="button-outlined"/>
        <Label fx:id="titleLabel" text="员工详情" styleClass="page-title"/>
    </HBox>

    <Separator/>

    <GridPane hgap="16" vgap="10" style="-fx-padding: 8 0 0 0;">
        <columnConstraints>
            <ColumnConstraints minWidth="80" prefWidth="80"/>
            <ColumnConstraints hgrow="ALWAYS"/>
        </columnConstraints>

        <Label text="ID" styleClass="bold" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <Label fx:id="idValue" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

        <Label text="姓名" styleClass="bold" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <Label fx:id="nameValue" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

        <Label text="性别" styleClass="bold" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <Label fx:id="genderValue" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

        <Label text="手机号" styleClass="bold" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
        <Label fx:id="phoneValue" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

        <Label text="邮箱" styleClass="bold" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
        <Label fx:id="emailValue" GridPane.columnIndex="1" GridPane.rowIndex="4" wrapText="true"/>

        <Label text="所属机构" styleClass="bold" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
        <Label fx:id="orgValue" GridPane.columnIndex="1" GridPane.rowIndex="5"/>

        <Label text="入职日期" styleClass="bold" GridPane.columnIndex="0" GridPane.rowIndex="6"/>
        <Label fx:id="hireDateValue" GridPane.columnIndex="1" GridPane.rowIndex="6"/>

        <Label text="出生日期" styleClass="bold" GridPane.columnIndex="0" GridPane.rowIndex="7"/>
        <Label fx:id="birthdayValue" GridPane.columnIndex="1" GridPane.rowIndex="7"/>

        <Label text="状态" styleClass="bold" GridPane.columnIndex="0" GridPane.rowIndex="8"/>
        <Label fx:id="statusValue" GridPane.columnIndex="1" GridPane.rowIndex="8"/>
    </GridPane>

</VBox>
