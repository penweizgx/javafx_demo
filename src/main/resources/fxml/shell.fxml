<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>

<StackPane fx:id="root" xmlns:fx="http://javafx.com/fxml" fx:controller="com.example.app.controller.ShellController">
    <BorderPane styleClass="app-shell">
        
        <top>
            <HBox styleClass="header-bar" alignment="CENTER_LEFT">
                
                <HBox fx:id="brandArea" styleClass="brand-area" alignment="CENTER_LEFT" spacing="8">
                    <ImageView fx:id="brandIcon" fitWidth="24" fitHeight="24" preserveRatio="true"/>
                    <Label fx:id="brandLabel" styleClass="brand-title"/>
                </HBox>
                
                <Region HBox.hgrow="ALWAYS"/>
                
                <HBox fx:id="systemArea" styleClass="system-area" alignment="CENTER_RIGHT" spacing="8">
                    <Button fx:id="btnSystem" styleClass="flat"/>
                    <Button fx:id="btnTheme" styleClass="flat"/>
                    <Label fx:id="userNameLabel"/>
                </HBox>
                
            </HBox>
        </top>
        
        <center>
            <BorderPane>
                <left>
                    <VBox styleClass="aside-nav" prefWidth="240" spacing="4">
                        <Button fx:id="btnHome" styleClass="nav-item" maxWidth="Infinity" alignment="CENTER_LEFT"/>
                        <Button fx:id="btnForm" styleClass="nav-item" maxWidth="Infinity" alignment="CENTER_LEFT"/>
                        <Button fx:id="btnList" styleClass="nav-item" maxWidth="Infinity" alignment="CENTER_LEFT"/>
                    </VBox>
                </left>
                <center>
                    <TabPane fx:id="tabPane" styleClass="content-area"/>
                </center>
            </BorderPane>
        </center>
        
        <bottom>
            <HBox styleClass="footer-bar" alignment="CENTER_LEFT">
                <Label fx:id="copyrightLabel"/>
            </HBox>
        </bottom>
        
    </BorderPane>
</StackPane>
