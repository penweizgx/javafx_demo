<?xml version="1.0" encoding="UTF-8"?>

<?import atlantafx.base.controls.Card?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="16.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.app.controller.UserDetailController">
    <padding>
        <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="10.0">
        <Label text="用户详情" styleClass="title-3" />
        <HBox spacing="8.0" HBox.hgrow="ALWAYS" alignment="CENTER_RIGHT">
            <Button fx:id="editButton" mnemonicParsing="false" onAction="#onEdit" text="编辑" styleClass="button-outlined" />
            <Button fx:id="saveButton" mnemonicParsing="false" onAction="#onSave" text="保存" visible="false" styleClass="accent" />
            <Button fx:id="cancelButton" mnemonicParsing="false" onAction="#onCancel" text="取消" visible="false" styleClass="button-outlined" />
        </HBox>
    </HBox>

    <Card>
        <header>
            <Label text="基本信息" styleClass="text-bold" />
        </header>
        <body>
            <GridPane hgap="12.0" vgap="8.0">
                <columnConstraints>
                    <ColumnConstraints minWidth="80.0" prefWidth="100.0" />
                    <ColumnConstraints hgrow="ALWAYS" />
                </columnConstraints>

                <Label text="昵称" styleClass="text-muted" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                <Label fx:id="nicknameLabel" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                <TextField fx:id="nicknameField" visible="false" managed="false" styleClass="rounded" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                <Label text="手机号" styleClass="text-muted" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                <Label fx:id="phoneLabel" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                <TextField fx:id="phoneField" visible="false" managed="false" styleClass="rounded" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                <Label text="邮箱" styleClass="text-muted" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                <Label fx:id="emailLabel" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                <TextField fx:id="emailField" visible="false" managed="false" styleClass="rounded" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                <Label text="状态" styleClass="text-muted" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                <Label fx:id="statusLabel" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                <Label text="创建时间" styleClass="text-muted" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                <Label fx:id="createTimeLabel" GridPane.columnIndex="1" GridPane.rowIndex="4" />
            </GridPane>
        </body>
    </Card>

</VBox>