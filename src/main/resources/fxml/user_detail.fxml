<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ProgressIndicator?>

<VBox fx:id="root" xmlns:fx="http://javafx.com/fxml" 
      fx:controller="com.example.app.controller.UserDetailController" 
      spacing="16" styleClass="page-container">
    
    <HBox fx:id="headerBox" spacing="16" alignment="CENTER_LEFT" styleClass="page-header">
        <Button fx:id="backBtn" text="返回"/>
        <Label fx:id="titleLabel" text="用户详情"/>
        <HBox HBox.hgrow="ALWAYS"/>
        <Button fx:id="editBtn" text="编辑"/>
        <Button fx:id="saveBtn" text="保存" visible="false" managed="false"/>
        <Button fx:id="cancelBtn" text="取消" visible="false" managed="false"/>
    </HBox>
    
    <Label fx:id="errorLabel" styleClass="error-message"/>
    
    <ProgressIndicator fx:id="loadingIndicator"/>
    
    <VBox fx:id="infoCard" spacing="16" styleClass="user-info-card">
        <style>
            -fx-background-color: #f8f9fa;
            -fx-background-radius: 8;
            -fx-padding: 20;
        </style>
        <GridPane fx:id="infoGrid" hgap="16" vgap="12">
            <columnConstraints>
                <ColumnConstraints minWidth="100" prefWidth="100"/>
                <ColumnConstraints hgrow="ALWAYS"/>
            </columnConstraints>
            
            <Label text="姓名:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
            <TextField fx:id="nameField" GridPane.columnIndex="1" GridPane.rowIndex="0" editable="false"/>
            
            <Label text="邮箱:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
            <TextField fx:id="emailField" GridPane.columnIndex="1" GridPane.rowIndex="1" editable="false"/>
            
            <Label text="电话:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
            <TextField fx:id="phoneField" GridPane.columnIndex="1" GridPane.rowIndex="2" editable="false"/>
            
            <Label text="部门:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
            <TextField fx:id="orgField" GridPane.columnIndex="1" GridPane.rowIndex="3" editable="false"/>
            
            <Label text="角色:" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
            <TextField fx:id="roleField" GridPane.columnIndex="1" GridPane.rowIndex="4" editable="false"/>
            
            <Label text="状态:" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
            <HBox spacing="8" alignment="CENTER_LEFT" GridPane.columnIndex="1" GridPane.rowIndex="5">
                <Label fx:id="statusBadge" styleClass="badge"/>
            </HBox>
            
            <Label text="创建时间:" GridPane.columnIndex="0" GridPane.rowIndex="6"/>
            <TextField fx:id="createTimeField" GridPane.columnIndex="1" GridPane.rowIndex="6" editable="false"/>
        </GridPane>
    </VBox>
    
</VBox>
